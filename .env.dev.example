# =============================================================================
# Macro Wallets (WaaS) - Development Environment
# =============================================================================
# Copy to .env.dev:  cp .env.dev.example .env.dev
# Free public RPC endpoints are pre-filled for quick local development.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=dev
ENVIRONMENT=development
APP_ENV=local
PORT=2002
# Goravel encryption — leave empty to auto-fill via `make` (artisan key:generate), or run: make key-generate
APP_KEY=
# JWT signing — leave empty then run: go run . --env=.env.dev artisan jwt:secret
JWT_SECRET=

# -----------------------------------------------------------------------------
# Docker-mapped host ports (change if you have conflicts)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
LOCALSTACK_PORT=4566

# -----------------------------------------------------------------------------
# Database (PostgreSQL — matches docker-compose defaults)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://vault:vault@localhost:5432/vault?sslmode=disable
TEST_DATABASE_URL=postgres://vault:vault@localhost:5432/vault_test?sslmode=disable
# Goravel ORM (must align with DATABASE_URL)
DB_CONNECTION=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=vault
DB_USERNAME=vault
DB_PASSWORD=vault
DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints (testnet / devnet — free, no key required)
# -----------------------------------------------------------------------------
ETH_RPC_URL=https://eth-sepolia.public.blastapi.io
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
SOLANA_RPC_URL=https://api.devnet.solana.com
BTC_RPC_URL=https://blockstream.info/testnet/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
API_KEY_SECRET=dev-secret-key-not-for-production
MASTER_KEY_REF=local:dev-master-key

# -----------------------------------------------------------------------------
# AWS Configuration (leave empty to use LocalStack)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AMZ_ACCESS_KEY_ID=
AMZ_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# SQS Queue URLs (leave empty for local; LocalStack auto-creates if needed)
# -----------------------------------------------------------------------------
WEBHOOK_QUEUE_URL=
WITHDRAWAL_QUEUE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
DEBUG=true
GRAPHQL_PLAYGROUND_ENABLED=true

# -----------------------------------------------------------------------------
# Monitoring (optional for local dev)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=1.0
