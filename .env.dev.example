# =============================================================================
# Development Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=dev
ENVIRONMENT=development
PORT=8080

# -----------------------------------------------------------------------------
# Docker-mapped host ports (change if you have conflicts)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050
LOCALSTACK_PORT=4566

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://vault:vault@localhost:5432/vault?sslmode=disable
TEST_DATABASE_URL=postgres://vault:vault@localhost:5432/vault_test?sslmode=disable

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints (Use testnet/devnet for development)
# -----------------------------------------------------------------------------
# Ethereum Sepolia Testnet
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon Mumbai Testnet
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Solana Devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Bitcoin Testnet
BTC_RPC_URL=https://blockstream.info/testnet/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
API_KEY_SECRET=dev-secret-key-not-for-production
MASTER_KEY_REF=local:dev-master-key

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AMZ_ACCESS_KEY_ID=
AMZ_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# SQS Queue URLs
# -----------------------------------------------------------------------------
WEBHOOK_QUEUE_URL=
WITHDRAWAL_QUEUE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
DEBUG=true
GRAPHQL_PLAYGROUND_ENABLED=true

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=1.0
