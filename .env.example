# =============================================================================
# Macro Wallets (WaaS) - Environment Configuration Template
# =============================================================================
# Copy this file to the appropriate env file and fill in your values:
#   cp .env.example .env.dev       (local development)
#   cp .env.example .env.staging   (staging)
#   cp .env.example .env.prod      (production — NEVER commit with real values)

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=dev                    # dev | staging | prod
ENVIRONMENT=development    # development | staging | production
PORT=2002                  # API server port (backend)

# -----------------------------------------------------------------------------
# Docker-mapped host ports (change if you have conflicts)
# -----------------------------------------------------------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
LOCALSTACK_PORT=4566

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://vault:vault@localhost:5432/vault?sslmode=disable
TEST_DATABASE_URL=postgres://vault:vault@localhost:5432/vault_test?sslmode=disable

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints
# -----------------------------------------------------------------------------
# Use testnet URLs for development, mainnet for production.
# See docs/RPC_PROVIDERS.md for provider options and free-tier limits.

# Ethereum (Sepolia testnet / Mainnet)
ETH_RPC_URL=https://eth-sepolia.public.blastapi.io

# Polygon (Amoy testnet / Mainnet)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# Solana (Devnet / Mainnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Bitcoin (Testnet / Mainnet)
BTC_RPC_URL=https://blockstream.info/testnet/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# HMAC secret for API authentication — generate with: openssl rand -hex 32
API_KEY_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Master encryption key reference (local for dev, KMS ARN for production)
MASTER_KEY_REF=local:dev-master-key

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AMZ_ACCESS_KEY_ID=
AMZ_SECRET_ACCESS_KEY=

# S3 bucket for SAM deployment artifacts (optional, SAM auto-resolves if empty)
S3_BUCKET=

# -----------------------------------------------------------------------------
# SQS Queue URLs (auto-populated by CloudFormation after deployment)
# -----------------------------------------------------------------------------
WEBHOOK_QUEUE_URL=
WITHDRAWAL_QUEUE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
DEBUG=true
GRAPHQL_PLAYGROUND_ENABLED=true

# -----------------------------------------------------------------------------
# Monitoring & Error Reporting
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Webhook Provider Keys (deposit monitoring via push notifications)
# -----------------------------------------------------------------------------
ALCHEMY_AUTH_TOKEN=
HELIUS_API_KEY=
QUICKNODE_API_KEY=
ETHERSCAN_API_KEY=
WEBHOOK_INGEST_BASE_URL=http://localhost:2002
