# =============================================================================
# Vault Custody Service - Environment Configuration Template
# =============================================================================
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in your values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=dev
ENVIRONMENT=development
PORT=8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://vault:vault@localhost:5432/vault?sslmode=disable

# For testing
TEST_DATABASE_URL=postgres://vault:vault@localhost:5432/vault_test?sslmode=disable

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints
# -----------------------------------------------------------------------------
# Ethereum Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Solana Mainnet
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Bitcoin Mainnet
BTC_RPC_URL=https://blockstream.info/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# API key secret for HMAC authentication (generate with: openssl rand -hex 32)
API_KEY_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Master encryption key reference (for KMS)
MASTER_KEY_REF=local:dev-master-key

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AMZ_ACCESS_KEY_ID=your_access_key_id
AMZ_SECRET_ACCESS_KEY=your_secret_access_key

# S3 Bucket for SAM deployments (optional)
S3_BUCKET=

# -----------------------------------------------------------------------------
# SQS Queue URLs (populated by CloudFormation after deployment)
# -----------------------------------------------------------------------------
WEBHOOK_QUEUE_URL=
WITHDRAWAL_QUEUE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable debug mode
DEBUG=true

# Enable GraphQL playground
GRAPHQL_PLAYGROUND_ENABLED=true

# -----------------------------------------------------------------------------
# Monitoring & Error Reporting
# -----------------------------------------------------------------------------
# Sentry DSN (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Third-Party Integrations (if needed)
# -----------------------------------------------------------------------------
# Add your third-party service credentials here
