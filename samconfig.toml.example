# SAM CLI config — generated by `sam deploy --guided`
# Copy to samconfig.toml and fill in your values.

version = 0.1

[default.deploy.parameters]
stack_name = "vault"
resolve_s3 = true
s3_prefix = "vault"
region = "us-east-1"
confirm_changeset = true
capabilities = "CAPABILITY_IAM"
parameter_overrides = """
  Environment=dev \
  DatabaseURL=postgres://vault:PASS@HOST:5432/vault?sslmode=require \
  RedisURL=redis://HOST:6379 \
  EthRpcURL=https://eth-mainnet.g.alchemy.com/v2/KEY \
  PolygonRpcURL=https://polygon-mainnet.g.alchemy.com/v2/KEY \
  SolanaRpcURL=https://api.mainnet-beta.solana.com \
  BtcRpcURL=https://blockstream.info/api \
  ApiKeySecret=CHANGE_ME \
  MasterKeyRef=local:dev
"""
