# =============================================================================
# Production Environment Configuration
# =============================================================================
# ⚠️  WARNING: Never commit this file with real credentials!

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=prod
ENVIRONMENT=production
PORT=8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL RDS)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://vault_prod:CHANGE_ME@your-rds-instance.region.rds.amazonaws.com:5432/vault_prod?sslmode=require

# -----------------------------------------------------------------------------
# Redis Cache (ElastiCache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://your-elasticache-endpoint.region.cache.amazonaws.com:6379

# -----------------------------------------------------------------------------
# Blockchain RPC Endpoints (Mainnet)
# -----------------------------------------------------------------------------
# Ethereum Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_PRODUCTION_KEY

# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_PRODUCTION_KEY

# Solana Mainnet
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Bitcoin Mainnet
BTC_RPC_URL=https://blockstream.info/api

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
API_KEY_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# KMS key reference
MASTER_KEY_REF=arn:aws:kms:us-east-1:ACCOUNT_ID:key/KEY_ID

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AMZ_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AMZ_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# S3 Bucket for deployments
S3_BUCKET=vault-deployments-prod

# -----------------------------------------------------------------------------
# SQS Queue URLs (auto-populated by CloudFormation)
# -----------------------------------------------------------------------------
WEBHOOK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vault-webhooks-prod
WITHDRAWAL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vault-withdrawals-prod

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
DEBUG=false
GRAPHQL_PLAYGROUND_ENABLED=false

# -----------------------------------------------------------------------------
# Monitoring & Error Reporting
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# Rate Limiting & Performance
# -----------------------------------------------------------------------------
MAX_CONNECTIONS=100
IDLE_CONNECTIONS=10
CONNECTION_LIFETIME=3600
