            "type": "object",
            "properties": {
                "external_user_id": {
                    "type": "string",
                    "example": "user_123"
                },
                "metadata": {
                    "type": "string",
                    "example": "{\"tier\":\"premium\"}"
                }
            }
        },
        "controllers.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
